@page "/"
@inject HttpClient Http

<div class="container py-5">

    <div class="d-flex align-items-center gap-3 mb-5">
        <div>
            <h1 class="display-6 fw-bold mb-0">Products</h1>
        </div>
        @if (products != null)
        {
            <span class="badge bg-primary rounded-pill ms-auto fs-6">@products.Count items</span>
        }
    </div>

    @if (isLoading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center py-5 gap-3">
            <div class="spinner-border text-primary" role="status" style="width:3rem;height:3rem;">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted">Fetching products…</p>
        </div>
    }
    else if (hasError)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                 class="bi bi-exclamation-triangle-fill flex-shrink-0" viewBox="0 0 16 16">
                <path
                d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2" />
            </svg>
            <div><strong>Unable to load products.</strong> Please try refreshing the page.</div>
        </div>
    }
    else if (products == null || !products.Any())
    {
        <div class="text-center py-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor"
                 class="bi bi-box-seam text-secondary mb-3" viewBox="0 0 16 16">
                <path
                d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2zm3.564 1.426L5.596 5 8 5.961 14.154 3.5zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923zM7.443.184a1.5 1.5 0 0 1 1.114 0l7.129 2.852A.5.5 0 0 1 16 3.5v8.662a1 1 0 0 1-.629.928l-7.185 2.874a.5.5 0 0 1-.372 0L.63 13.09a1 1 0 0 1-.63-.928V3.5a.5.5 0 0 1 .314-.464z" />
            </svg>
            <h5 class="text-secondary">No products found</h5>
            <p class="text-muted small">Your inventory is empty. Add some products to get started.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
            @foreach (var product in products)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body d-flex flex-column gap-2 p-4">
                            @if (product.Category is not null)
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle fw-normal small" style="max-width: fit-content;">
                                    @product.Category.Name
                                </span>
                            }
                            <h5 class="card-title fw-semibold mb-1">@product.Name</h5>
                           
                            <p class="card-text fs-4 fw-bold text-primary mb-0">@product.ToUsdPrice()</p>
                            <div class="mt-auto pt-2 d-flex justify-content-between align-items-center border-top">
                                <span class="text-muted small">Stock</span>
                                @{
                                    var (badgeClass, label) = product.Stock > 10
                                        ? ("bg-success-subtle text-success border border-success-subtle", $"{product.Stock} available")
                                        : product.Stock > 0
                                            ? ("bg-warning-subtle text-warning border border-warning-subtle", $"{product.Stock} low")
                                            : ("bg-danger-subtle text-danger border border-danger-subtle", "Out of stock");
                                }
                                <span class="badge rounded-pill @badgeClass fw-semibold">@label</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

@code {
    private List<Product>? products;
    private bool isLoading = true;
    private bool hasError = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            products = await Http.GetFromJsonAsync<List<Product>>("products");
            products = products?.OrderBy(p => p.Category?.Name).ToList();
            
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching products: {ex.Message}");
            hasError = true;
        }
        finally
        {
            isLoading = false;
        }
    }
}
